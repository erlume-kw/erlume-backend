{
  "_description": "Canonical model field reference for Backoffice. Matches Mongoose schemas. ObjectIds as OBJECT_ID.",
  "Address": {
    "street": "string",
    "city": "string",
    "block": "string",
    "governorate": "string",
    "house": "string",
    "flat": "string (optional)"
  },
  "User": {
    "_id": "OBJECT_ID",
    "password": "string",
    "emailAddress": "string",
    "phoneNumber": "string",
    "address": "Address",
    "roles": ["string"],
    "cardIds": ["OBJECT_ID"],
    "isDeleted": "boolean",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Seller": {
    "_id": "OBJECT_ID",
    "userId": "OBJECT_ID (ref User)",
    "fullName": "string",
    "emailAddress": "string",
    "phoneNumber": "string",
    "addressText": "string",
    "balance": "string",
    "itemIds": ["OBJECT_ID (ref Item)"],
    "IBAN": "string",
    "qrCode": "string",
    "isDeactivated": "boolean",
    "consentGiven": "boolean",
    "preferredPickupDate": "string",
    "intakeTimestamp": "string",
    "sellerPolicyAcceptedAt": "date (optional)",
    "escalationStatus": "string (optional, enum: none, seller_no_response, escalated, resolved)",
    "escalationNotes": "string (optional)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Category": {
    "_id": "OBJECT_ID",
    "name": "string",
    "base_rate": "string",
    "op_rate": "string",
    "clean_rate": "string",
    "sub_category_id": "OBJECT_ID (optional)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "SubCategory": {
    "_id": "OBJECT_ID",
    "sub_cat_name": "string",
    "category_id": "OBJECT_ID (ref Category)",
    "demand_id": "OBJECT_ID (optional, ref Demand)",
    "sub_clean_rate": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Demand": {
    "_id": "OBJECT_ID",
    "demand_name": "string",
    "demand_rate": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Drop": {
    "_id": "OBJECT_ID",
    "name": "string",
    "description": "string",
    "releaseDate": "date",
    "status": "string (enum)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Item": {
    "_id": "OBJECT_ID",
    "basePrice": "string",
    "condition": "string (enum)",
    "uploadedAt": "date",
    "saleRate": "string",
    "itemStatus": "string (enum)",
    "color": "string",
    "size": "string",
    "itemName": "string",
    "itemModel": "string",
    "year": "string",
    "quantity": "string",
    "brandName": "string (only brand field; do not use brand)",
    "imageUrls": ["string"],
    "receiptPhotoUrls": ["string"],
    "priceEstimatorUrls": ["string"],
    "quoteUrls": ["string"],
    "approved": "boolean",
    "approvedNextDrop": "boolean",
    "orderId": "OBJECT_ID (optional, ref Order)",
    "authNeeded": "boolean",
    "cleaningNeeded": "boolean",
    "listingPrice": "string (required)",
    "photographed": "boolean",
    "authenticationStatus": "string (optional, enum: pending, authentic, not_authentic)",
    "authenticatedAt": "date (optional)",
    "returnDate": "date (optional)",
    "returnStatus": "string (optional, enum: pending, scheduled, returned, not_returned)",
    "seller_id": "OBJECT_ID (optional, ref User)",
    "category_id": "OBJECT_ID (ref Category)",
    "sub_category_id": "OBJECT_ID (optional, ref SubCategory)",
    "drop_id": "OBJECT_ID (optional, ref Drop)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Order": {
    "_id": "OBJECT_ID",
    "user_id": "OBJECT_ID (ref User)",
    "orderitem_ids": ["OBJECT_ID (ref OrderItem)"],
    "order_status": "string (enum)",
    "deliveryDate": "date (optional)",
    "deliveryStatus": "string (optional, enum: pending, shipped, delivered, failed)",
    "trackingReference": "string (optional)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "OrderItem": {
    "_id": "OBJECT_ID",
    "order_id": "OBJECT_ID (ref Order)",
    "is_returned": "boolean",
    "item_id": "OBJECT_ID (ref Item)",
    "quantity": "number",
    "price": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Transaction": {
    "_id": "OBJECT_ID",
    "order_id": "OBJECT_ID (ref Order)",
    "discount_rate": "string",
    "amount": "string",
    "discount_id": "OBJECT_ID (optional, ref DiscountCode)",
    "status": "string (enum)",
    "paymentMethod": "string (optional, enum)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Sale": {
    "_id": "OBJECT_ID",
    "order_id": "OBJECT_ID (ref Order)",
    "order_item_id": "OBJECT_ID (ref OrderItem)",
    "transaction_id": "OBJECT_ID (optional, ref Transaction)",
    "invoice_number": "string",
    "invoice_url": "string",
    "payment_evidence_url": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Income": {
    "_id": "OBJECT_ID",
    "order_id": "OBJECT_ID (optional)",
    "order_item_id": "OBJECT_ID (optional)",
    "item_id": "OBJECT_ID (optional)",
    "seller_id": "OBJECT_ID (optional, ref User)",
    "amount": "string (total/sale amount)",
    "erlumeCommissionAmount": "string (optional)",
    "sellerPayoutAmount": "string (optional)",
    "currency": "string",
    "platform": "string",
    "income_type": "string",
    "received_at": "date",
    "notes": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Expense": {
    "_id": "OBJECT_ID",
    "name": "string",
    "cost": "string",
    "currency": "string (optional, default KWD)",
    "employee_id": "OBJECT_ID (optional, ref User) — Employee",
    "notes": "string",
    "type": ["string"],

    "month": "date",
    "paidBy": "string (optional) — Paid By",
    "isRecurring": "boolean (optional) — Recurring?",
    "phase": "string (optional) — e.g. Pre-launch",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "DiscountCode": {
    "_id": "OBJECT_ID",
    "code": "string",
    "discount_percentage": "string",
    "expiry_date": "date",
    "is_active": "boolean",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "CreditCard": {
    "_id": "OBJECT_ID",
    "cardNumber": "string",
    "expiryDate": "string",
    "holderName": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Outfit": {
    "_id": "OBJECT_ID",
    "item_ids": ["OBJECT_ID (ref Item)"],
    "outfit_title": "string",
    "outfit_tags": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "OutfitItem": {
    "_id": "OBJECT_ID",
    "item_id": "OBJECT_ID (ref Item)",
    "outfit_id": "OBJECT_ID (ref Outfit)",
    "featured_in_product": "boolean",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Review": {
    "_id": "OBJECT_ID",
    "userId": "OBJECT_ID (optional, ref User)",
    "sellerId": "OBJECT_ID (ref Seller)",
    "rating": "number (1-5)",
    "description": "string",
    "createdAt": "date",
    "updatedAt": "date"
  }
}
