{
  "_description": "Canonical model field reference for Backoffice. Matches Mongoose schemas. ObjectIds as OBJECT_ID.",
  "Address": {
    "street": "string",
    "city": "string",
    "block": "string",
    "governorate": "string",
    "house": "string",
    "flat": "string (optional)"
  },
  "User": {
    "_id": "OBJECT_ID",
    "password": "string",
    "emailAddress": "string",
    "phoneNumber": "string",
    "address": "Address",
    "roles": [
      "string"
    ],
    "cardIds": [
      "OBJECT_ID"
    ],
    "isDeleted": "boolean",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Seller": {
    "_id": "OBJECT_ID",
    "userId": "OBJECT_ID (ref User)",
    "fullName": "string (optional, default: empty string)",
    "emailAddress": "string (optional)",
    "phoneNumber": "string (optional)",
    "addressText": "string (optional, default: empty string)",
    "balance": "string",
    "itemIds": [
      "OBJECT_ID (ref Item)"
    ],
    "IBAN": "string (optional)",
    "qrCode": "string (optional)",
    "isDeactivated": "boolean (default: false)",
    "consentGiven": "boolean (optional, default: false)",
    "preferredPickupDate": "string (optional, default: empty string)",
    "intakeTimestamp": "string (optional)",
    "sellerPolicyAcceptedAt": "date (optional)",
    "escalationStatus": "string (optional, enum: none, seller_no_response, escalated, resolved)",
    "escalationNotes": "string (optional)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Category": {
    "_id": "OBJECT_ID",
    "name": "string",
    "base_rate": "string",
    "op_rate": "string (optional)",
    "clean_rate": "string (optional)",
    "sub_category_id": "OBJECT_ID (optional)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "SubCategory": {
    "_id": "OBJECT_ID",
    "sub_cat_name": "string",
    "category_id": "OBJECT_ID (ref Category)",
    "demand_id": "OBJECT_ID (optional, ref Demand)",
    "sub_clean_rate": "string (optional)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Demand": {
    "_id": "OBJECT_ID",
    "demand_name": "string",
    "demand_rate": "string (optional)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Drop": {
    "_id": "OBJECT_ID",
    "name": "string",
    "description": "string",
    "releaseDate": "date",
    "status": "string (enum)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Item": {
    "_id": "OBJECT_ID",
    "basePrice": "string",
    "condition": "string (enum)",
    "uploadedAt": "date",
    "saleRate": "string",
    "itemStatus": "string (enum)",
    "color": "string",
    "size": "string",
    "itemName": "string",
    "itemModel": "string",
    "year": "string",
    "quantity": "string",
    "brandName": "string (only brand field; do not use brand)",
    "imageUrls": [
      "string"
    ],
    "receiptPhotoUrls": [
      "string"
    ],
    "priceEstimatorUrls": [
      "string"
    ],
    "quoteUrls": [
      "string"
    ],
    "approved": "boolean",
    "approvedNextDrop": "boolean",
    "orderId": "OBJECT_ID (optional, ref Order)",
    "authNeeded": "boolean",
    "cleaningNeeded": "boolean",
    "listingPrice": "string (required)",
    "photographed": "boolean",
    "authenticationStatus": "string (optional, enum: pending, authentic, not_authentic)",
    "authenticatedAt": "date (optional)",
    "returnDate": "date (optional)",
    "returnStatus": "string (optional, enum: pending, scheduled, returned, not_returned)",
    "seller_id": "OBJECT_ID (optional, ref User)",
    "category_id": "OBJECT_ID (ref Category)",
    "sub_category_id": "OBJECT_ID (optional, ref SubCategory)",
    "drop_id": "OBJECT_ID (optional, ref Drop)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Order": {
    "_id": "OBJECT_ID",
    "user_id": "OBJECT_ID (ref User)",
    "orderitem_ids": [
      "OBJECT_ID (ref OrderItem)"
    ],
    "order_status": "string (enum)",
    "deliveryDate": "date (optional)",
    "deliveryStatus": "string (optional, enum: pending, shipped, delivered, failed)",
    "trackingReference": "string (optional)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "OrderItem": {
    "_id": "OBJECT_ID",
    "order_id": "OBJECT_ID (ref Order)",
    "is_returned": "boolean",
    "item_id": "OBJECT_ID (ref Item)",
    "quantity": "number",
    "price": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Transaction": {
    "_id": "OBJECT_ID",
    "order_id": "OBJECT_ID (ref Order)",
    "discount_rate": "string",
    "amount": "string",
    "discount_id": "OBJECT_ID (optional, ref DiscountCode)",
    "status": "string (enum)",
    "paymentMethod": "string (optional, enum)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Sale": {
    "_id": "OBJECT_ID",
    "order_id": "OBJECT_ID (optional, ref Order)",
    "order_item_id": "OBJECT_ID (optional, ref OrderItem)",
    "item_id": "OBJECT_ID (optional, ref Item)",
    "transaction_id": "OBJECT_ID (optional, ref Transaction)",
    "amount": "string (optional) — Total listing price (gross)",
    "listingPrice": "string (optional)",
    "erlumeCommission": "string (optional) — Erlume's cut from this sale",
    "sellerPayout": "string (optional) — Seller's cut",
    "buyer": "string (optional)",
    "status": "string (optional)",
    "sale_date": "date (optional, indexed)",
    "bag_record": "string (optional)",
    "invoice_number": "string (optional)",
    "invoice_url": "string (optional)",
    "payment_evidence_url": "string (optional)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Income": {
    "_id": "OBJECT_ID",
    "order_id": "OBJECT_ID (optional, ref Order)",
    "order_item_id": "OBJECT_ID (optional, ref OrderItem)",
    "item_id": "OBJECT_ID (optional, ref Item)",
    "seller_id": "OBJECT_ID (optional, ref User)",
    "amount": "string (required) — Erlume commission (what got to Erlume's bank, excludes seller payout)",
    "erlumeCommissionAmount": "string (optional, deprecated: use amount)",
    "sellerPayoutAmount": "string (optional)",
    "currency": "string (default: KWD)",
    "platform": "string (optional)",
    "income_type": "string (default: sale)",
    "received_at": "date (default: Date.now, indexed)",
    "month": "date (optional, indexed)",
    "prelaunch_bag": "string (optional) — Item ref text when item_id not linked. Format: Name-Brand-Year",
    "notes": "string (optional)",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Expense": {
    "_id": "OBJECT_ID",
    "name": "string",
    "cost": "string",
    "currency": "string (optional, default: KWD)",
    "employee_id": "OBJECT_ID (optional, ref User) — Employee",
    "notes": "string (optional, default: empty string)",
    "type": [
      "string"
    ],
    "month": "date",
    "paidBy": "string (optional) — Paid By",
    "isRecurring": "boolean (optional, default: false) — Recurring?",
    "phase": "string (optional) — e.g. Pre-launch",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "DiscountCode": {
    "_id": "OBJECT_ID",
    "code": "string",
    "discount_percentage": "string",
    "expiry_date": "date",
    "is_active": "boolean",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "CreditCard": {
    "_id": "OBJECT_ID",
    "cardNumber": "string",
    "expiryDate": "string",
    "holderName": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Outfit": {
    "_id": "OBJECT_ID",
    "item_ids": [
      "OBJECT_ID (ref Item)"
    ],
    "outfit_title": "string",
    "outfit_tags": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "OutfitItem": {
    "_id": "OBJECT_ID",
    "item_id": "OBJECT_ID (ref Item)",
    "outfit_id": "OBJECT_ID (ref Outfit)",
    "featured_in_product": "boolean",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Review": {
    "_id": "OBJECT_ID",
    "userId": "OBJECT_ID (optional, ref User)",
    "sellerId": "OBJECT_ID (ref Seller)",
    "rating": "number (1-5, enum)",
    "description": "string",
    "createdAt": "date",
    "updatedAt": "date"
  },
  "Employee": {
    "_id": "OBJECT_ID",
    "name": "string",
    "photo": "string (optional)",
    "role": "string (optional)",
    "type": "string (optional)",
    "salaryActual": "string (optional)",
    "salaryProjected": "string (optional)",
    "user_id": "OBJECT_ID (optional, ref User)",
    "createdAt": "date",
    "updatedAt": "date"
  }
}