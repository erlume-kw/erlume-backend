  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",  
    "moduleResolution": "node",  
    "rootDir": "./src",  
    "outDir": "dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
