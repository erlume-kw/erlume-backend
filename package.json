{
  "name": "backend-1.0",
  "version": "1.0.0",
  "description": "Backend using ExpressJS and MongoDB",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "start:dev": "npx nodemon src/server.ts",
    "build-and-run": "npm run build && npm start",
    "sync-db": "npx ts-node src/scripts/syncDb.ts",
    "bulk-import-sellers": "npx ts-node src/scripts/bulk-import-sellers.ts",
    "bulk-import-items": "ts-node src/scripts/bulk-import-items.ts",
    "bulk-import-csv-data": "npx ts-node src/scripts/bulk-import-csv-data.ts",
    "bulk-import-csv-data:clear": "npx ts-node src/scripts/bulk-import-csv-data.ts --clear",
    "add-seller": "npx ts-node src/scripts/add-seller.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erlume-kw/backend-1.0.git"
  },
  "author": "",
