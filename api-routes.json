          "body": "Item object (see models.json for full schema)",
          "response": "Created Item object"
        },
        {
          "method": "PUT",
          "path": "/api/items/:id",
          "description": "Update item (full)",
          "params": {
            "id": "ObjectId (required)"
          },
          "body": "Partial Item object",
          "response": "Updated Item object"
        },
        {
          "method": "PATCH",
          "path": "/api/items/:id",
          "description": "Update item (partial)",
          "params": {
            "id": "ObjectId (required)"
          },
          "body": "Partial Item object",
          "response": "Updated Item object"
        },
        {
          "method": "DELETE",
          "path": "/api/items/:id",
          "description": "Delete item",
          "params": {
            "id": "ObjectId (required)"
          },
          "response": "Success message"
        }
      ]
    },
    "orders": {
      "basePath": "/api/orders",
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/orders",
          "description": "List all orders",
          "queryParams": {
            "status": "string (optional, order status)",
            "year": "number (optional)",
            "month": "number (optional, 1-12)"
          },
          "response": "Array of Order objects"
        },
        {
          "method": "GET",
          "path": "/api/orders/user/:userId",
          "description": "Get orders by user ID",
          "params": {
            "userId": "ObjectId (required)"
          },
          "queryParams": {
            "year": "number (optional)",
            "month": "number (optional, 1-12)"
          },
          "response": "Array of Order objects"
        },
        {
          "method": "GET",
          "path": "/api/orders/:id",
          "description": "Get order by ID",
          "params": {
            "id": "ObjectId (required)"
          },
          "response": "Order object with populated orderItems"
        },
        {
          "method": "POST",
          "path": "/api/orders",
          "description": "Create new order",
          "body": {
            "user_id": "ObjectId (required)",
            "orderItems": [
              {
                "item_id": "ObjectId (required)",
                "quantity": "number (optional, min 1, default 1)",
                "is_returned": "boolean (optional)"
              }
            ],
            "order_status": "string (optional, enum, defaults to 'Pending')"
          },
          "response": "Created Order object"
        },
        {
          "method": "PATCH",
          "path": "/api/orders/:id",
          "description": "Update order (partial)",
          "params": {
            "id": "ObjectId (required)"
          },
          "body": {
            "order_status": "string (optional)",
            "deliveryDate": "date (optional)",
            "deliveryStatus": "string (optional)",
            "trackingReference": "string (optional)"
          },
          "response": "Updated Order object"
        },
        {
          "method": "PATCH",
          "path": "/api/orders/:id/status",
          "description": "Update order status only",
          "params": {
            "id": "ObjectId (required)"
          },
          "body": {
            "order_status": "string (required, enum)"
          },
          "response": "Updated Order object"
        },
        {
          "method": "DELETE",
          "path": "/api/orders/:id",
          "description": "Delete order",
          "params": {
            "id": "ObjectId (required)"
          },
          "response": "Success message"
        }
      ]
    },
