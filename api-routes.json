    "drops": {
      "basePath": "/api/drops",
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/drops",
          "description": "List all drops",
          "response": "Array of Drop objects"
        },
        {
          "method": "GET",
          "path": "/api/drops/:id",
          "description": "Get drop by ID",
          "params": {
            "id": "ObjectId (required)"
          },
          "response": "Drop object"
        },
        {
          "method": "GET",
          "path": "/api/drops/:id/items",
          "description": "Get items in a drop",
          "params": {
            "id": "ObjectId (required)"
          },
          "response": "Array of Item objects"
        },
        {
          "method": "POST",
          "path": "/api/drops",
          "description": "Create drop",
          "body": {
            "name": "string (required)",
            "description": "string (optional)",
            "releaseDate": "date (required)",
            "status": "string (optional, enum: 'upcoming', 'active', 'ended', default: 'upcoming')"
          },
          "response": "Created Drop object",
          "notes": "When drop status is 'upcoming', items in the drop are automatically set to 'pending'. When status is 'active', items are set to 'available'."
        },
        {
          "method": "POST",
          "path": "/api/drops/:id/items",
          "description": "Add items to drop",
          "params": {
            "id": "ObjectId (required)"
          },
          "body": {
            "itemId": "ObjectId (optional, single item)",
            "itemIds": "ObjectId[] (optional, multiple items)"
          },
          "response": "Success message with count",
          "notes": "Items added to a drop with status 'upcoming' are automatically set to 'pending'. Items added to a drop with status 'active' are automatically set to 'available'."
        },
        {
          "method": "PUT",
          "path": "/api/drops/:id",
          "description": "Update drop",
          "params": {
            "id": "ObjectId (required)"
          },
          "body": "Partial Drop object",
          "response": "Updated Drop object",
          "notes": "When drop status is updated to 'upcoming', all items in the drop are automatically set to 'pending'. When status is updated to 'active', all items are set to 'available'."
        },
        {
          "method": "DELETE",
          "path": "/api/drops/:id",
          "description": "Delete drop",
          "params": {
            "id": "ObjectId (required)"
          },
          "response": "Success message"
        },
        {
          "method": "DELETE",
          "path": "/api/drops/:id/items/:itemId",
          "description": "Remove item from drop",
          "params": {
            "id": "ObjectId (required)",
            "itemId": "ObjectId (required)"
          },
          "response": "Success message"
        }
      ]
    },
