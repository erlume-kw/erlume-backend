{
  "_description": "Complete API routes reference for Frontend/Backoffice. Base URL: http://localhost:3000",
  "_version": "1.0.0",
  "_lastUpdated": "2024-12-20",
  "routes": {
    "users": {
      "basePath": "/api/users",
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/users",
          "description": "List all users",
          "queryParams": {
            "includeDeleted": "string (optional, 'true' or 'false')",
            "role": "string (optional, filter by role)"
          },
          "response": "Array of User objects"
        },
        {
          "method": "GET",
          "path": "/api/users/:id",
          "description": "Get user by ID",
          "params": {
            "id": "ObjectId (required)"
          },
          "response": "User object with seller info if seller"
        },
        {
          "method": "POST",
          "path": "/api/users",
          "description": "Create new user",
          "body": {
            "password": "string (required, min 6 chars)",
            "emailAddress": "string (required, valid email)",
            "phoneNumber": "string (required, 7-15 digits)",
            "address": {
              "street": "string (required)",
              "city": "string (required)",
              "block": "string (required)",
              "governorate": "string (required)",
              "house": "string (required)",
              "flat": "string (optional)"
            },
            "roles": "string[] (optional, defaults to ['user'])",
            "consentGiven": "boolean|string (optional)",
            "preferredPickupDate": "string (optional)"
          },
          "response": "Created User object"
        },
        {
          "method": "PUT",
          "path": "/api/users/:id",
          "description": "Update user (full update)",
          "params": {
            "id": "ObjectId (required)"
          },
          "body": "Partial User object",
          "response": "Updated User object"
        },
        {
          "method": "PATCH",
          "path": "/api/users/:id",
          "description": "Update user (partial update)",
          "params": {
            "id": "ObjectId (required)"
          },
          "body": "Partial User object (e.g., { isDeleted: true })",
          "response": "Updated User object"
        },
        {
          "method": "PUT",
          "path": "/api/users/:id/roles",
          "description": "Update user roles",
          "params": {
            "id": "ObjectId (required)"
          },
          "body": {
            "roles": "string[] (required, min 1 role)"
          },
          "response": "Updated User object"
        },
        {
          "method": "DELETE",
          "path": "/api/users/:id",
          "description": "Soft delete user",
          "params": {
            "id": "ObjectId (required)"
          },
          "response": "Success message"
        }
      ]
    },
    "sellers": {
      "basePath": "/api/sellers",
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/sellers",
          "description": "List all sellers",
          "queryParams": {
            "includeDeactivated": "string (optional, 'true' to include deactivated)"
          },
          "response": "Array of Seller objects"
        },
        {
          "method": "GET",
          "path": "/api/sellers/:id",
          "description": "Get seller by ID (accepts seller _id or userId)",
          "params": {
            "id": "ObjectId (required, seller _id or userId)"
          },
          "response": "Seller object"
        },
        {
          "method": "POST",
          "path": "/api/sellers",
          "description": "Create new seller (creates user + seller)",
          "body": {
            "password": "string (required)",
            "emailAddress": "string (required)",
            "phoneNumber": "string (required)",
            "address": "Address object (required)",
            "fullName": "string (optional)",
            "addressText": "string (optional)",
            "consentGiven": "boolean|string (optional)",
            "preferredPickupDate": "string (optional)",
            "intakeTimestamp": "string (optional)"
          },
          "response": "Created User and Seller objects"
        },
        {
          "method": "PUT",
          "path": "/api/sellers/:id",
          "description": "Update seller info",
          "params": {
            "id": "ObjectId (required, seller _id or userId)"
          },
          "body": {
            "isDeactivated": "boolean (optional)",
            "fullName": "string (optional)",
            "emailAddress": "string (optional)",
            "phoneNumber": "string (optional)",
            "addressText": "string (optional)",
            "balance": "string (optional)",
            "IBAN": "string (optional)",
            "qrCode": "string (optional)",
            "consentGiven": "boolean|string (optional)",
            "preferredPickupDate": "string (optional)",
            "sellerPolicyAcceptedAt": "date (optional)",
            "escalationStatus": "string (optional)",
            "escalationNotes": "string (optional)"
          },
          "response": "Updated Seller object"
        },
        {
          "method": "PATCH",
          "path": "/api/sellers/:id",
          "description": "Update seller info (partial)",
          "params": {
            "id": "ObjectId (required)"
          },
          "body": "Partial Seller object",
          "response": "Updated Seller object"
        },
        {
          "method": "DELETE",
          "path": "/api/sellers/:id",
          "description": "Deactivate seller and soft-delete user",
          "params": {
            "id": "ObjectId (required)"
          },
          "response": "Success message"
        }
      ]
    },
    "items": {
      "basePath": "/api/items",
      "endpoints": [
        {
          "method": "GET",
          "path": "/api/items",
          "description": "List all items",
